generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  passwordHash       String         @map("password_hash")
  name               String
  locale             String         @default("nl")
  role               String         @default("user") // "user" | "admin"
  status             String         @default("pending") // "pending" | "approved" | "suspended"
  storyCredits       Int            @default(0) @map("story_credits")
  lastLoginAt        DateTime?      @map("last_login_at")
  phone              String?
  street             String?
  houseNumber        String?        @map("house_number")
  postalCode         String?        @map("postal_code")
  city               String?
  country            String?
  newsletterOptIn    Boolean        @default(false) @map("newsletter_opt_in")
  newsletterOptInAt  DateTime?      @map("newsletter_opt_in_at") // AVG-bewijs van consent
  firstStoryEmailSentAt DateTime?   @map("first_story_email_sent_at") // idempotency-flag
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  children           ChildProfile[]
  subscription       Subscription?
  adminNotes         AdminNote[]    @relation("NotesAboutUser")
  authoredNotes      AdminNote[]    @relation("NotesByAdmin")
  resetTokens        PasswordResetToken[]

  @@map("users")
}

/// Audit trail of admin-side mutations. Append-only — never deleted, even
/// when the admin user is removed. `adminId` is intentionally NOT a foreign
/// key so log rows survive admin-account deletion; admin email/name are
/// denormalised so the row makes sense in isolation.
model AdminAuditLog {
  id          String   @id @default(uuid())
  adminId     String?  @map("admin_id")
  adminEmail  String   @map("admin_email")
  adminName   String   @map("admin_name")
  /// Dot-separated action key, e.g. "user.approve", "user.delete",
  /// "password.reset_link_generated", "story.set_landing_slot".
  action      String
  targetType  String?  @map("target_type") // "user" | "story" | "child" | "subscription" | etc.
  targetId    String?  @map("target_id")
  metadata    Json?    // free-form context: old/new values, reason, etc.
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("admin_audit_log")
}

/// Nieuwsbrief-aanmeldingen van bezoekers zonder account (footer-formulier).
/// Account-houders staan in `users.newsletter_opt_in` en hoeven hier niet in.
model NewsletterSignup {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String?
  source         String    @default("footer") // "footer" | "register" | "manual"
  ip             String?
  optInAt        DateTime  @default(now()) @map("opt_in_at") // AVG
  unsubscribedAt DateTime? @map("unsubscribed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("newsletter_signups")
}

/// Tokens for password-reset flow (self-service or admin-initiated).
/// Raw token lives in the reset link; only the SHA-256 hash is stored.
model PasswordResetToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdByAdminId String? @map("created_by_admin_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// Placeholder subscription model — not wired to a payment provider yet.
model Subscription {
  id               String    @id @default(uuid())
  userId           String    @unique @map("user_id")
  plan             String    @default("free") // "free" | "basic" | "premium"
  status           String    @default("active") // "active" | "cancelled" | "expired" | "trialing"
  startedAt        DateTime  @default(now()) @map("started_at")
  endsAt           DateTime? @map("ends_at")
  cancelledAt      DateTime? @map("cancelled_at")
  stripeCustomerId String?   @map("stripe_customer_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

/// Internal notes an admin can attach to any user for support context.
model AdminNote {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  authorId  String   @map("author_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  user   User @relation("NotesAboutUser", fields: [userId], references: [id], onDelete: Cascade)
  author User @relation("NotesByAdmin", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("admin_notes")
}

model ChildProfile {
  id                       String   @id @default(uuid())
  userId                   String   @map("user_id")
  name                     String
  dateOfBirth              DateTime @map("date_of_birth") @db.Date
  gender                   String   // "boy" | "girl" | "other"
  interests                String[] // e.g. ["dinosaurs", "space", "animals"]
  pets                     Json?    // [{ name, type, description }]
  friends                  Json?    // [{ name, relationship }]
  favoriteThings           Json?    @map("favorite_things") // { color, food, toy, place }
  fears                    String[] // things to avoid in stories
  hairColor                String?  @map("hair_color")       // e.g. "blond", "bruin", "rood"
  hairStyle                String?  @map("hair_style")       // e.g. "kort", "lang", "krullen"
  eyeColor                 String?  @map("eye_color")        // e.g. "blauw", "bruin", "groen"
  skinColor                String?  @map("skin_color")       // e.g. "licht", "getint", "donker"
  wearsGlasses             Boolean  @default(false) @map("wears_glasses")
  hasFreckles              Boolean  @default(false) @map("has_freckles")
  mainCharacterType        String   @map("main_character_type") // "self" | "stuffed_animal" | "action_hero" | "custom"
  mainCharacterDescription String?  @map("main_character_description")
  approvedCharacterPrompt  String?  @map("approved_character_prompt") // locked prompt after parent approval
  approvedPreviewUrl       String?  @map("approved_preview_url")      // the approved preview image URL
  characterBible           Json?    @map("character_bible") // grows over time with story summaries
  referenceImages          String[] @map("reference_images") // S3/R2 URLs — raw uploads
  // ── Character LoRA (fal.ai flux-lora-fast-training) ──
  // Status flow: none → uploaded → training → ready | failed
  loraStatus               String   @default("none") @map("lora_status")
  loraUrl                  String?  @map("lora_url")          // diffusers_lora_file URL
  loraTrainingRequestId    String?  @map("lora_training_request_id") // fal request_id for polling
  loraTriggerWord          String?  @map("lora_trigger_word") // unique per child, must appear in prompt
  loraTrainedAt            DateTime? @map("lora_trained_at")
  loraConsentAt            DateTime? @map("lora_consent_at")  // GDPR audit trail
  loraFailureReason        String?  @map("lora_failure_reason")
  loraReadyEmailSentAt     DateTime? @map("lora_ready_email_sent_at") // idempotency-flag
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories Story[]
  books   StoryBook[]

  @@map("child_profiles")
}

model Story {
  id                  String      @id @default(uuid())
  childProfileId      String      @map("child_profile_id")
  title               String
  subtitle            String?
  language            String      @default("nl") // "nl" | "en"
  setting             String      // e.g. "fantasy_forest", "space_adventure"
  status              String      @default("generating") // "generating" | "ready" | "error"
  generationParams    Json?       @map("generation_params") // questions/answers for this story
  isFavorite          Boolean     @default(false) @map("is_favorite")
  // Optional marker for landing-page previews. One of: "girl-2" | "girl-4"
  // | "boy-2" | "boy-4" — null = not a preview. Only one story per slot is
  // shown (most recent wins if somehow duplicated).
  landingPreviewSlot  String?     @map("landing_preview_slot")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  childProfile ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  pages        StoryPage[]
  jobs         GenerationJob[]
  bookStories  BookStory[]

  @@index([landingPreviewSlot])
  @@map("stories")
}

model StoryPage {
  id                      String @id @default(uuid())
  storyId                 String @map("story_id")
  pageNumber              Int    @map("page_number")
  text                    String
  illustrationUrl         String? @map("illustration_url") // S3/R2 URL
  illustrationPrompt      String? @map("illustration_prompt") // for regeneration
  illustrationDescription String? @map("illustration_description") // alt text

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, pageNumber])
  @@map("story_pages")
}

model StoryBook {
  id              String   @id @default(uuid())
  childProfileId  String   @map("child_profile_id")
  title           String
  subtitle        String?
  dedication      String?
  coverStyle      String?  @map("cover_style")  // "night" | "cream" | "linen"
  format          String?                         // "soft" | "hard" | "deluxe"
  coverImageUrl   String?  @map("cover_image_url")
  interiorPdfUrl  String?  @map("interior_pdf_url")
  coverPdfUrl     String?  @map("cover_pdf_url")
  printStatus     String   @default("draft") @map("print_status") // "draft" | "pdf_ready" | "ordered" | "printed" | "shipped"
  printJobId      String?  @map("print_job_id") // Lulu print job ID
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  childProfile ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  bookStories  BookStory[]

  @@map("story_books")
}

model BookStory {
  id          String @id @default(uuid())
  bookId      String @map("book_id")
  storyId     String @map("story_id")
  sortOrder   Int    @map("sort_order")

  book  StoryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  story Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([bookId, storyId])
  @@map("book_stories")
}

/// Fixed-window rate limiting counters.
/// One row per (user, action) combination. Reset atomically when the window expires.
model RateLimit {
  key         String   @id // e.g. "story-create:<userId>" or "preview:<userId>"
  count       Int      @default(0)
  windowStart DateTime @default(now()) @map("window_start")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("rate_limits")
}

model GenerationJob {
  id           String    @id @default(uuid())
  storyId      String    @map("story_id")
  type         String    // "text" | "illustration" | "pdf"
  status       String    @default("pending") // "pending" | "processing" | "completed" | "failed"
  progress     Int       @default(0) // 0-100
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")
  completedAt  DateTime? @map("completed_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@map("generation_jobs")
}
