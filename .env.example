# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/hetjongetje_dev"

# Auth
AUTH_SECRET="generate-a-random-secret-here"

# AI Services
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Image Generation (Flux 2 via fal.ai)
FAL_KEY="your-fal-ai-key"

# Storage (Scaleway Object Storage, S3-compatible)
# Region: nl-ams (Amsterdam) houdt data in Nederland
SCALEWAY_REGION="nl-ams"
SCALEWAY_BUCKET="ons-verhaaltje-prod"
SCALEWAY_ACCESS_KEY="your-access-key"
SCALEWAY_SECRET_KEY="your-secret-key"
# Optional: custom public URL (leave empty to use default virtual-hosted style)
# SCALEWAY_PUBLIC_BASE_URL="https://images.onsverhaaltje.nl"

# Error monitoring (Sentry, EU region)
# DSN is public; safe to expose via NEXT_PUBLIC_ so client can report too.
NEXT_PUBLIC_SENTRY_DSN=""
# Optional: server-only DSN if you want the server to report to a different project
# SENTRY_DSN=""
# Required only when uploading source maps during builds (prod/CI):
SENTRY_ORG="ons-verhaaltje"
SENTRY_PROJECT="ons-verhaaltje-web"
SENTRY_AUTH_TOKEN=""

# Transactional e-mail (Brevo, EU servers)
# Genereer een v3 API-key via https://app.brevo.com/settings/keys/api
# Zonder key wordt mail naar de console gelogd (handig in dev).
BREVO_API_KEY=""
# ID van de Nieuwsbrief-lijst in Brevo (Contacts → Lists)
BREVO_NEWSLETTER_LIST_ID="3"
# Geheim in de webhook-URL die Brevo aanroept bij unsubscribe-events
# Brevo URL wordt: https://onsverhaaltje.nl/api/brevo/webhook?secret=<deze-waarde>
BREVO_WEBHOOK_SECRET="generate-a-random-string-here"
# E-mailadres dat notificaties krijgt bij nieuwe aanmeldingen (testfase)
ADMIN_EMAIL="admin@onsverhaaltje.nl"

# Print (Lulu - Phase 3)
# LULU_API_KEY="your-lulu-api-key"
