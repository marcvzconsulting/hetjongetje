# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# graphify (generated knowledge graph)
/graphify-out/
.graphify_python

# claude code local settings
.claude/settings.local.json

# design exploration (not for production)
/src/app/design-exploration/
/src/design-exploration/
/public/design-exploration/

# fal.ai spot variant candidates — regenerate with `pnpm gen:spots`
/public/images/spot-candidates/
